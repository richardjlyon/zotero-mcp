<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.zotero-mcp.http</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/sh</string>
        <string>-c</string>
        <string>exec /Users/rjl/.cargo/bin/zotero-mcp</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>ZOTERO_MCP_HTTP</key>
        <string>127.0.0.1:8765</string>
        <!-- Replace with your Tailscale Funnel hostname. Must match the
             public URL clients reach exactly: scheme + host, no trailing
             slash. OAuth discovery embeds this verbatim. -->
        <key>ZOTERO_MCP_OAUTH_ISSUER</key>
        <string>https://laptop.stoat-minnow.ts.net</string>
        <key>RUST_LOG</key>
        <string>info,tower_http=debug</string>
        <!-- launchd's default PATH is /usr/bin:/bin, which hides the
             ocrmypdf (~/.local/bin) and pdftotext (Homebrew) binaries the
             PDF extraction stack resolves at startup. -->
        <key>PATH</key>
        <string>/Users/rjl/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>StandardOutPath</key>
    <string>/Users/rjl/Library/Logs/zotero-mcp/http.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/rjl/Library/Logs/zotero-mcp/http.err.log</string>
</dict>
</plist>
